<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>Emf2Svg</PackageId>
    <Version>1.0.2</Version>
    <Authors>Zerohidz</Authors>
    <Description>A pure C# library for converting EMF (Enhanced Metafile) to SVG. No native dependencies.</Description>
    <PackageTags>emf;svg;converter;metafile;graphics</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/Zerohidz/Emf2Svg</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <Compile Remove="Emf2Svg.Cli/**" />
  </ItemGroup>

</Project>
